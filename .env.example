# 동행복권 로또 자동 구매 봇 환경 설정
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env

# 동행복권 로그인 정보
DHL_USER_ID=your_id_here
DHL_USER_PW=your_password_here

# Slack 알림 설정
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=#your-channel

# 구매 설정
LOTTO_COUNT=1

# 실행 옵션
HEADLESS=true
DEBUG=false
DEBUG_ARTIFACTS=false
DEBUG_DIR=artifacts
